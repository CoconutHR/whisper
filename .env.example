# whisper does not load this file automatically. Export these values in the
# process environment or copy them into the service manager configuration.
WHISPER_R2_ACCOUNT_ID=your-cloudflare-account-id
WHISPER_R2_ACCESS_KEY_ID=your-r2-access-key-id
WHISPER_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
WHISPER_R2_BUCKET=whisper-files
